# Oky Mobile App - Environment Configuration
#
# Copy this file to .env and configure for your environment.
# Or run: yarn copy-config (from project root)

##############################################################################
# ANDROID CONFIGURATION
##############################################################################

# Path to Android SDK (required for Android builds)
# Update this to match your local Android SDK installation
ANDROID_SDK_ROOT=/Users/dev/Library/Android/sdk

##############################################################################
# API ENDPOINTS
##############################################################################

# Backend API URL
# Local development: http://localhost:3000
# For Android emulator: http://10.0.2.2:3000 (or use adb reverse)
# Production: https://your-api-domain.com
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# CMS API URL
# Local development: http://localhost:5000
# For Android emulator: http://10.0.2.2:5000 (or use adb reverse)
# Production: https://your-cms-domain.com
EXPO_PUBLIC_API_BASE_CMS_URL=http://localhost:5000

##############################################################################
# OPTIONAL SERVICES
##############################################################################

# External prediction service endpoint (optional)
# If not set, the app uses the built-in prediction engine
EXPO_PUBLIC_PREDICTION_ENDPOINT=

# Website URL for external links (optional)
EXPO_PUBLIC_WEBSITE_URL=

# Audio content base URL for voice-over features (optional)
EXPO_PUBLIC_AUDIO_BASE_URL=

##############################################################################
# DEVELOPMENT FLAGS
##############################################################################

# Enable offline mode (useful for testing without backend)
# Uncomment to enable:
# EXPO_OFFLINE=1

# Enable fast sign-up (skip some validation for faster testing)
# Uncomment to enable:
# EXPO_PUBLIC_FAST_SIGN_UP=1

# Environment mode (development/production)
# Uncomment to set:
# EXPO_PUBLIC_ENV=development

##############################################################################
# FIREBASE CONFIGURATION (Required)
##############################################################################

# Firebase configuration files must be placed in:
# - app/src/resources/google-services.json (Android)
# - app/src/resources/GoogleService-Info.plist (iOS)
#
# Get these files from your Firebase project console:
# https://console.firebase.google.com/

##############################################################################
# NOTES
##############################################################################

# For Android Emulator Development:
# The emulator cannot access localhost directly. Options:
# 1. Use adb reverse: yarn reverse:all-ports
# 2. Use 10.0.2.2 instead of localhost in API URLs
# 3. Use your machine's IP address on the local network

# Running the app:
# - Start backend first: yarn dev (from project root)
# - Then start app: yarn dev:app (from project root)
# - Or: cd app && yarn start

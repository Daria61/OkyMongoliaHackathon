# Oky Period Tracker - Root Environment Configuration
#
# This is a reference file showing all environment variables used across the project.
# For actual configuration, run: yarn copy-config
# This will create .env files in app/, packages/api/, and packages/cms/ from their .env.dist templates.

##############################################################################
# MOBILE APP (app/.env)
##############################################################################

# Android SDK path (required for Android builds)
ANDROID_SDK_ROOT=/Users/dev/Library/Android/sdk

# API endpoints (local development)
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
EXPO_PUBLIC_API_BASE_CMS_URL=http://localhost:5000

# Optional: External prediction service endpoint
EXPO_PUBLIC_PREDICTION_ENDPOINT=

# Optional: Website URL for external links
EXPO_PUBLIC_WEBSITE_URL=

# Optional: Audio content base URL (for voice-over features)
EXPO_PUBLIC_AUDIO_BASE_URL=

# Development flags (uncomment to enable)
# EXPO_OFFLINE=1                    # Enable offline mode for testing
# EXPO_PUBLIC_FAST_SIGN_UP=1        # Skip some validation for faster testing
# EXPO_PUBLIC_ENV=development       # Set environment (development/production)

##############################################################################
# BACKEND API (packages/api/.env)
##############################################################################

# Environment
NODE_ENV=development

# Application secrets (CHANGE THESE IN PRODUCTION!)
APPLICATION_SECRET=!ChangeMe!
SECONDARY_APPLICATION_SECRET=new_secret

# Server ports
API_PORT=3000
CMS_PORT=5000

# Account deletion redirect URL
DELETE_ACCOUNT_URL=https://oky-period-tracker.github.io/periodtracker_delete_account-whitelabelled/

# Database configuration (PostgreSQL)
DATABASE_TYPE=postgres
DATABASE_HOST=postgres              # Use 'localhost' if not using Docker
DATABASE_PORT=5432
DATABASE_USERNAME=periodtracker
DATABASE_PASSWORD=periodtracker
DATABASE_NAME=periodtracker
DATABASE_SCHEMA=periodtracker
DATABASE_SYNCHRONIZE=false          # NEVER set to true in production
DATABASE_LOGGING=true               # Set to false in production

##############################################################################
# CMS (packages/cms/.env)
##############################################################################

# Environment
NODE_ENV=development

# Passport authentication secret (CHANGE THIS IN PRODUCTION!)
PASSPORT_SECRET=!ChangeMe!

# Server ports
API_PORT=3000
CMS_PORT=5000

# Database configuration (PostgreSQL)
DATABASE_TYPE=postgres
DATABASE_HOST=postgres              # Use 'localhost' if not using Docker
DATABASE_PORT=5432
DATABASE_USERNAME=periodtracker
DATABASE_PASSWORD=periodtracker
DATABASE_NAME=periodtracker
DATABASE_SCHEMA=periodtracker
DATABASE_SYNCHRONIZE=false          # NEVER set to true in production
DATABASE_LOGGING=true               # Set to false in production

# Localization
DEFAULT_LOCALE=en

# Optional: Cloud storage configuration (for file uploads)
STORAGE_BUCKET=
STORAGE_BASE_URL=

##############################################################################
# FIREBASE CONFIGURATION (Required)
##############################################################################

# Firebase configuration files must be placed manually:
# - app/src/resources/google-services.json (Android)
# - app/src/resources/GoogleService-Info.plist (iOS)
# - packages/cms/firebase-config.json (CMS)
#
# Get these files from your Firebase project console.

##############################################################################
# DOCKER ENVIRONMENT
##############################################################################

# When running with Docker (yarn dev), services are available at:
# - API: http://localhost:3000
# - CMS: http://localhost:5000
# - Adminer (DB Admin): http://localhost:8080
# - PostgreSQL: localhost:5432

##############################################################################
# PRODUCTION NOTES
##############################################################################

# Before deploying to production:
# 1. Change all secrets (APPLICATION_SECRET, PASSPORT_SECRET, etc.)
# 2. Set NODE_ENV=production
# 3. Set DATABASE_LOGGING=false
# 4. Set DATABASE_SYNCHRONIZE=false (always!)
# 5. Update API URLs in app/.env to production endpoints
# 6. Configure proper STORAGE_BUCKET and STORAGE_BASE_URL
# 7. Ensure Firebase is configured for production

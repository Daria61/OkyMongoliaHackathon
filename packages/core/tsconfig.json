{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "es2015",
    "module": "commonjs",
    "allowJs": false,
    "composite": true,
    "declaration": true,
    "noEmit": false,
    "outDir": "dist/",
    "rootDir": "src",
    "typeRoots": ["../../node_modules/@types"],
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": []
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.json"
  ],
  "exclude": [
    "**/*.test.ts", // Exclude test files
    "dist/" // Exclude output folder
  ]
}

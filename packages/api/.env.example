# Oky Backend API - Environment Configuration
#
# Copy this file to .env and configure for your environment.
# Or run: yarn copy-config (from project root)

##############################################################################
# ENVIRONMENT
##############################################################################

# Application environment (development/production)
NODE_ENV=development

##############################################################################
# APPLICATION SECRETS
##############################################################################

# Primary application secret for JWT token signing
# IMPORTANT: Change this to a strong, random value in production!
# Generate with: openssl rand -base64 32
APPLICATION_SECRET=!ChangeMe!

# Secondary application secret (for token rotation/migration)
# IMPORTANT: Change this to a strong, random value in production!
SECONDARY_APPLICATION_SECRET=new_secret

##############################################################################
# SERVER CONFIGURATION
##############################################################################

# API server port
API_PORT=3000

# CMS server port (needed for cross-service communication)
CMS_PORT=5000

##############################################################################
# EXTERNAL URLS
##############################################################################

# URL for account deletion instructions page
DELETE_ACCOUNT_URL=https://oky-period-tracker.github.io/periodtracker_delete_account-whitelabelled/

##############################################################################
# DATABASE CONFIGURATION (PostgreSQL)
##############################################################################

# Database type (always postgres for this project)
DATABASE_TYPE=postgres

# Database host
# Use 'postgres' when running with Docker
# Use 'localhost' when running database locally
DATABASE_HOST=postgres

# Database port (default PostgreSQL port)
DATABASE_PORT=5432

# Database credentials
DATABASE_USERNAME=periodtracker
DATABASE_PASSWORD=periodtracker

# Database name
DATABASE_NAME=periodtracker

# Database schema
DATABASE_SCHEMA=periodtracker

# Auto-sync database schema with TypeORM entities
# WARNING: NEVER set to true in production! Always use migrations.
DATABASE_SYNCHRONIZE=false

# Enable SQL query logging (useful for debugging)
# Set to false in production for better performance
DATABASE_LOGGING=true

##############################################################################
# PRODUCTION NOTES
##############################################################################

# Before deploying to production:
# 1. Set NODE_ENV=production
# 2. Generate strong, unique secrets for APPLICATION_SECRET and SECONDARY_APPLICATION_SECRET
# 3. Use secure database credentials
# 4. Set DATABASE_SYNCHRONIZE=false (critical!)
# 5. Set DATABASE_LOGGING=false (for performance)
# 6. Use environment-specific DATABASE_HOST (not 'postgres')
# 7. Ensure DELETE_ACCOUNT_URL points to production page

##############################################################################
# DOCKER DEVELOPMENT
##############################################################################

# When using Docker (yarn dev from project root):
# - API runs on http://localhost:3000
# - CMS runs on http://localhost:5000
# - Database is accessible via 'postgres' hostname (internal)
# - Database is accessible via 'localhost:5432' (external)
# - Adminer (DB admin) runs on http://localhost:8080

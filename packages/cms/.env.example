# Oky CMS - Environment Configuration
#
# Copy this file to .env and configure for your environment.
# Or run: yarn copy-config (from project root)

##############################################################################
# ENVIRONMENT
##############################################################################

# Application environment (development/production)
NODE_ENV=development

##############################################################################
# AUTHENTICATION
##############################################################################

# Passport.js session secret for admin authentication
# IMPORTANT: Change this to a strong, random value in production!
# Generate with: openssl rand -base64 32
PASSPORT_SECRET=!ChangeMe!

##############################################################################
# SERVER CONFIGURATION
##############################################################################

# API server port (needed for cross-service communication)
API_PORT=3000

# CMS server port
CMS_PORT=5000

##############################################################################
# DATABASE CONFIGURATION (PostgreSQL)
##############################################################################

# Database type (always postgres for this project)
DATABASE_TYPE=postgres

# Database host
# Use 'postgres' when running with Docker
# Use 'localhost' when running database locally
DATABASE_HOST=postgres

# Database port (default PostgreSQL port)
DATABASE_PORT=5432

# Database credentials
DATABASE_USERNAME=periodtracker
DATABASE_PASSWORD=periodtracker

# Database name
DATABASE_NAME=periodtracker

# Database schema
DATABASE_SCHEMA=periodtracker

# Auto-sync database schema with TypeORM entities
# WARNING: NEVER set to true in production! Always use migrations.
DATABASE_SYNCHRONIZE=false

# Enable SQL query logging (useful for debugging)
# Set to false in production for better performance
DATABASE_LOGGING=true

##############################################################################
# LOCALIZATION
##############################################################################

# Default locale for the CMS interface
# Available locales: en (English), mn (Mongolian), id (Indonesian)
DEFAULT_LOCALE=en

##############################################################################
# CLOUD STORAGE (Optional)
##############################################################################

# Cloud storage bucket name (e.g., AWS S3, Google Cloud Storage)
# Leave empty to use local file storage
STORAGE_BUCKET=

# Base URL for accessing uploaded files
# Leave empty if using local storage
# Example: https://storage.googleapis.com/your-bucket
# Example: https://your-bucket.s3.amazonaws.com
STORAGE_BASE_URL=

##############################################################################
# FIREBASE CONFIGURATION (Required)
##############################################################################

# Firebase configuration file must be placed at:
# packages/cms/firebase-config.json
#
# Get this file from your Firebase project console:
# https://console.firebase.google.com/
# Project Settings > Service Accounts > Generate New Private Key

##############################################################################
# INITIAL CMS USER SETUP
##############################################################################

# After first login, create a CMS admin user:
# 1. Go to http://localhost:8080 (Adminer)
# 2. Login with database credentials
# 3. Navigate to the 'user' or 'cms_user' table
# 4. Insert a new user record with hashed password
# 5. See docs/start_project.md for SQL command

##############################################################################
# PRODUCTION NOTES
##############################################################################

# Before deploying to production:
# 1. Set NODE_ENV=production
# 2. Generate a strong, unique PASSPORT_SECRET
# 3. Use secure database credentials
# 4. Set DATABASE_SYNCHRONIZE=false (critical!)
# 5. Set DATABASE_LOGGING=false (for performance)
# 6. Configure cloud storage (STORAGE_BUCKET and STORAGE_BASE_URL)
# 7. Ensure Firebase configuration is for production project
# 8. Set up proper admin user authentication
# 9. Remove any test/temporary admin accounts

##############################################################################
# DOCKER DEVELOPMENT
##############################################################################

# When using Docker (yarn dev from project root):
# - API runs on http://localhost:3000
# - CMS runs on http://localhost:5000
# - Database is accessible via 'postgres' hostname (internal)
# - Database is accessible via 'localhost:5432' (external)
# - Adminer (DB admin) runs on http://localhost:8080
#
# Access CMS at: http://localhost:5000

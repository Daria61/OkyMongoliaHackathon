# Development stage
# FROM --platform=linux/amd64 oky/base as development
FROM oky/base as development

ENV NODE_ENV=development
WORKDIR /usr/src/app/packages/cms

CMD [ "yarn", "run", "watch" ]

# Production stage
# FROM --platform=linux/amd64 node:20 as production
FROM node:20 as production

ENV NODE_ENV=production
WORKDIR /usr/src/app

COPY --from=oky/base /usr/src/cms/node_modules ./node_modules
COPY --from=oky/base /usr/src/cms/packages/cms/package.json .
COPY --from=oky/base /usr/src/cms/packages/cms/dist ./dist

COPY --from=oky/base /usr/src/cms/packages/core/package.json ./packages/core/package.json
COPY --from=oky/base /usr/src/cms/packages/core/dist ./packages/core/dist

WORKDIR /usr/src/app/packages/cms

CMD [ "yarn", "start" ]